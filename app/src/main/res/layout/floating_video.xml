<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/float_root"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_float_video">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:resize_mode="fit" app:use_controller="false"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <FrameLayout android:id="@+id/controls_layer"
        android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@+id/btn_close"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_float_close"
            android:padding="2dp"
            android:contentDescription="@string/close"/>

        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView android:id="@+id/btn_replay"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginEnd="20dp"
                android:src="@drawable/ic_replay_10"
                android:background="@drawable/bg_float_play_side"
                android:scaleType="center"
                android:contentDescription="@string/video_back_10"/>
            <ImageView android:id="@+id/btn_play_pause"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_float_play_main"
                android:scaleType="center"
                android:contentDescription="@string/video_play"/>
            <ImageView android:id="@+id/btn_forward"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/ic_forward_10"
                android:background="@drawable/bg_float_play_side"
                android:scaleType="center"
                android:contentDescription="@string/video_forward_10"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="8dp">
            <TextView android:id="@+id/txt_current"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_inverse" android:textSize="11sp"/>
            <SeekBar android:id="@+id/seek_bar"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp" android:layout_marginEnd="6dp"
                android:progressTint="@color/float_progress_loaded"
                android:progressBackgroundTint="@color/float_progress_unloaded"
                android:thumbTint="@color/nebula_blue"/>
            <TextView android:id="@+id/txt_duration"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_inverse" android:textSize="11sp"/>
        </LinearLayout>
    </FrameLayout>

    <ImageView android:id="@+id/resize_handle"
        android:layout_width="24dp" android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_drag_handle"
        android:scaleType="center"
        android:background="@drawable/bg_float_resize_handle"
        android:padding="3dp"
        android:contentDescription="缩放"/>
</FrameLayout>
