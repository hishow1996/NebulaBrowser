<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    app:cardCornerRadius="12dp" app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_card"
    android:layout_margin="4dp">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="8dp">
        <ImageView android:id="@+id/book_cover"
            android:layout_width="match_parent" android:layout_height="180dp"
            android:src="@drawable/ic_book" android:scaleType="centerCrop"
            android:background="@color/bg_input"/>
        <TextView android:id="@+id/book_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:text="书名"
            android:textColor="@color/text_primary" android:textSize="14sp"
            android:maxLines="2" android:ellipsize="end"/>
        <ProgressBar android:id="@+id/book_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="3dp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
